{
  "name": "gallery",
  "version": "0.1.8",
  "repository": "https://github.com/dk8990/gallery-app",
  "main": "dist-main/index.js",
  "scripts": {
    "build-main": "tsc -p main/tsconfig.json",
    "dev": "npm run build-main && concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build && npm run build-main && electron-builder",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.gallery.app",
    "productName": "Gallery",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "files": [
      "dist-main/**/*",
      "out/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/ffprobe-static/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.6",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ffprobe-static": "^2.0.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
